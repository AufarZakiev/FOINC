{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "importHelpers": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "vue": ["./node_modules/vue"],
      "@/*": ["./src/*"],
      "@upload-ui/*": ["../modules/upload/ui/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "../modules/upload/ui/**/*.vue",
    "../modules/upload/ui/**/*.ts",
    "../modules/pyodide-runtime/ui/**/*.vue",
    "../modules/pyodide-runtime/ui/**/*.ts",
    "../integrations/ui/**/*.ts"
  ],
  "exclude": ["../modules/**/ui/__tests__/**"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
